# LLM Inference Service Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Model Settings
# =============================================================================

# HuggingFace model identifier
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Number of GPUs for tensor parallelism (set to number of available GPUs)
TENSOR_PARALLEL_SIZE=1

# Fraction of GPU memory to use (0.0-1.0)
GPU_MEMORY_UTILIZATION=0.90

# Maximum number of concurrent sequences
MAX_NUM_SEQS=256

# Maximum model context length (leave empty for model default)
MAX_MODEL_LEN=

# Data type for model weights (auto, float16, bfloat16, float32)
DTYPE=auto

# Disable CUDA graphs for debugging (slower but more compatible)
ENFORCE_EAGER=false

# Trust remote code from HuggingFace models
TRUST_REMOTE_CODE=true

# =============================================================================
# Server Settings
# =============================================================================

# Server bind address
HOST=0.0.0.0

# Server port
PORT=8000

# Number of worker processes (for uvicorn)
WORKERS=1

# Enable debug mode (enables auto-reload)
DEBUG=false

# Graceful shutdown timeout in seconds
SHUTDOWN_TIMEOUT=30

# =============================================================================
# CORS Settings
# =============================================================================

# Allowed origins (comma-separated, use * for all)
CORS_ORIGINS=*

# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Batching Settings
# =============================================================================

# Maximum batch size
MAX_BATCH_SIZE=32

# Maximum wait time for batching (milliseconds)
MAX_WAIT_TIME_MS=100

# Request timeout (milliseconds)
REQUEST_TIMEOUT_MS=30000

# Maximum queue size
MAX_QUEUE_SIZE=1000

# =============================================================================
# HuggingFace Settings
# =============================================================================

# HuggingFace API token (required for gated models like Llama 2)
HF_TOKEN=

# =============================================================================
# Redis Settings
# =============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Connection pool size
REDIS_POOL_SIZE=10

# Enable response caching
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL_SECONDS=3600

# Temperature threshold for caching (only cache deterministic responses)
CACHE_TEMPERATURE_THRESHOLD=0.01

# =============================================================================
# Rate Limiting Settings
# =============================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Sliding window size in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# Use Redis for distributed rate limiting (falls back to in-memory if false)
RATE_LIMIT_USE_REDIS=true

# =============================================================================
# Timeout Settings
# =============================================================================

# Maximum time for generation requests in seconds
GENERATION_TIMEOUT_SECONDS=120

# Maximum time between streaming chunks in seconds
STREAMING_CHUNK_TIMEOUT_SECONDS=30
